alias config='$(which git) --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'

alias viz="vi $HOME/.zshrc"
alias siz="source $HOME/.zshrc"

alias pd pushdir

alias cat=bat --paging=never
alias ls='exa -l --group-directories-first --color=auto --git --icons --no-permissions --no-user'
alias ll='exa -lahF --group-directories-first --color=auto --git --icons'

alias start_postgres="pg_ctl -D /usr/local/var/postgres start"
alias stop_postgres="pg_ctl -D /usr/local/var/postgres stop -s -m fast"
alias pgup="start_postgres"
alias pgdown="stop_postgres"
alias mongoup="brew services start mongodb-community"
alias mongodown="brew services stop mongodb-community"

