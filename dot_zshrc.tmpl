# ~/.zshrc — managed by chezmoi (macos-dotfiles)
# Machine: {{ .machine }} | Profile applied: {{ now | date "2006-01-02" }}

# ── Terminal settings ─────────────────────────────────────────────────────────
# Must be before the instant prompt preamble — writes escape sequences to terminal.
tabs -2

# ── Homebrew ──────────────────────────────────────────────────────────────────
# Must be before instant prompt preamble so antigen (which needs brew) loads first.
if [[ "$(uname -m)" == "arm64" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
else
  eval "$(/usr/local/bin/brew shellenv)"
fi

# ── antigen (plugin manager) ──────────────────────────────────────────────────
# Loaded before the instant prompt preamble: antigen can write to stdout on first
# run or when updating plugins, which would trigger the p10k console output warning.
source "$(brew --prefix)/share/antigen/antigen.zsh"
antigen init ~/.antigenrc

# ── Powerlevel10k instant prompt ──────────────────────────────────────────────
# Everything above this line is allowed to produce console output.
# Everything below must not write to the terminal during initialisation.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ── GNU tools (use without 'g' prefix) ───────────────────────────────────────
export PATH="$(brew --prefix)/opt/gnu-sed/libexec/gnubin:$PATH"
export PATH="$(brew --prefix)/opt/coreutils/libexec/gnubin:$PATH"

# ── PATH additions ────────────────────────────────────────────────────────────
export PATH="$HOME/bin:/usr/local/sbin:$PATH"

# ── nvm ───────────────────────────────────────────────────────────────────────
export NVM_DIR="$HOME/.nvm"
[ -s "$(brew --prefix)/opt/nvm/nvm.sh" ]                        && source "$(brew --prefix)/opt/nvm/nvm.sh"
[ -s "$(brew --prefix)/opt/nvm/etc/bash_completion.d/nvm" ]     && source "$(brew --prefix)/opt/nvm/etc/bash_completion.d/nvm"

# ── pyenv ─────────────────────────────────────────────────────────────────────
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv &>/dev/null; then
  eval "$(pyenv init -)"
fi

# ── java ──────────────────────────────────────────────────────────────────────
export PATH="$(brew --prefix)/opt/openjdk/bin:$PATH"

# ── z (frecent directory jumps) ───────────────────────────────────────────────
source "$(brew --prefix)/etc/profile.d/z.sh" 2>/dev/null || true

# ── fzf ───────────────────────────────────────────────────────────────────────
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_OPTS='--height 40% --preview="cat {}" --preview-window=right:60%:wrap'

# ── hstr (Ctrl-R history browser) ────────────────────────────────────────────
export HSTR_CONFIG=hicolor
bindkey -s "\C-r" "\C-a hstr -- \C-j"

# ── editor ────────────────────────────────────────────────────────────────────
export EDITOR="emacs -nw"
export VISUAL="emacs"

# ── history ───────────────────────────────────────────────────────────────────
HISTSIZE=50000
SAVEHIST=50000
HISTFILE="$HOME/.zsh_history"
HIST_STAMPS="yyyy-mm-dd"
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt SHARE_HISTORY

# ── ssh (1Password SSH agent) ────────────────────────────────────────────────
# 1Password manages SSH keys via its agent. If not using 1Password, comment this
# out and add your key manually: ssh-add ~/.ssh/id_ed25519
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# ── aliases ───────────────────────────────────────────────────────────────────
source "$HOME/.zsh_aliases"

# ── chezmoi shortcuts ─────────────────────────────────────────────────────────
alias cz='chezmoi'
alias czd='chezmoi diff'
alias cza='chezmoi apply'
alias cze='chezmoi edit'
alias czu='chezmoi update'

# ── brew shortcuts ────────────────────────────────────────────────────────────
alias bup='brew update && brew upgrade && brew cleanup'

CONFIG_DIR="${HOME}/.local/share/macos-config"
PROFILE="{{ .machine }}"
alias brewup="brew bundle --no-lock --file=${CONFIG_DIR}/Brewfile.common && brew bundle --no-lock --file=${CONFIG_DIR}/Brewfile.${PROFILE}"

# ── terraform completions ─────────────────────────────────────────────────────
autoload -U +X bashcompinit && bashcompinit
if command -v terraform &>/dev/null; then
  complete -o nospace -C "$(brew --prefix)/bin/terraform" terraform
fi

# ── powerlevel10k theme ───────────────────────────────────────────────────────
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# ── work-specific configuration ───────────────────────────────────────────────
{{ if eq .machine "work" -}}

# sdkman (Java version manager)
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

# Work project helpers
force_master_pull() {
  cd "$1" &&
  git restore . &&
  git checkout master &&
  git pull &&
  npm install &&
  popd
}

# AWS credentials — stored in 1Password.
# To set up: create an item named "AWS CLI" in your "Work" vault with fields:
#   access_key_id, secret_access_key
# Then uncomment the lines below:
#
# export AWS_ACCESS_KEY_ID="$(op read "op://Work/AWS CLI/access_key_id")"
# export AWS_SECRET_ACCESS_KEY="$(op read "op://Work/AWS CLI/secret_access_key")"
#
# Alternatively, use AWS SSO: aws configure sso

{{- end }}

# ── local overrides (not tracked by chezmoi) ──────────────────────────────────
# Put machine-specific secrets and overrides in ~/.zshrc.local — not tracked by chezmoi.
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
