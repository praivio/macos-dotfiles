#### ANTIGEN CONFIGURATION ####
source $(brew --prefix)/share/antigen/antigen.zsh
antigen init ~/.antigenrc
#### END ANTIGEN CONFIGURATION ####

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export PATH=$HOME/bin:/usr/local/sbin:/usr/local/opt/openssl/bin:$PATH

HIST_STAMPS="yyyy-mm-dd"

# Source aliases from separate aliases dotfile
source $HOME/.zsh_aliases

force_master_pull() {
   cd $1 &&
   git restore . &&
   git checkout master &&
   git pull &&
   npm install &&
   popd
}

export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion

export SSH_KEY_FILE=$HOME/.ssh/id_rsa

{{- if eq .chezmoi.hostname "work-laptop" }}
# Santa Monica stuff

export ELISA_SMN_HOME=$HOME/Elisa/smn

if [[ -d $ELISA_SMN_HOME ]]; then
   export ELISA_SMN_DEV_HOME=$ELISA_SMN_HOME/smn-dev
   export ELISA_SMN_DOCKER_COMPOSE_CONFIG=$ELISA_SMN_DEV_HOME/docker-compose.yml

   alias smncd="cd $ELISA_SMN_DEV_HOME"
   alias smnnpmci='for dir in $(ls */package.json | sed "s/\/.*//"); do (cd $dir && npm ci); done'
   alias smnps="docker-compose -f $ELISA_SMN_DOCKER_COMPOSE_CONFIG ps"
   alias smnup="docker-compose -f $ELISA_SMN_DOCKER_COMPOSE_CONFIG up -d"
fi
{{- end }}

# pyenv
